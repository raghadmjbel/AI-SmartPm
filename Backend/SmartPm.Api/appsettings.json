{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=SmartPmDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "AIService": {
    "BaseUrl": "http://127.0.0.1:8000",
    "TimeoutSeconds": 60,
    "MaxRetries": 3
  },
  "RateLimiting": {
    "PermitLimit": 10,
    "WindowSeconds": 90,
    "RequestsPerMinute": 60,
    "BurstCapacity": 20
  },
  "Jwt": {
    "Key": "your-super-secret-key-here-make-it-long-and-secure",
    "Issuer": "SmartPm.Api",
    "Audience": "SmartPm.Client"
  }
}
