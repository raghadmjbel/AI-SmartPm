{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=SmartPmDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "AIService": {
    "BaseUrl": "http://ai-service:8000",
    "TimeoutSeconds": 60,
    "MaxRetries": 3
  },
  "RateLimiting": {
    "PermitLimit": 10,
    "WindowSeconds": 60,
    "RequestsPerMinute": 60,
    "BurstCapacity": 20
  }
}
